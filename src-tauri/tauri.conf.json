{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Track Republic",
  "version": "1.0.0",
  "identifier": "com.nicolocampagnoli.cashflowtracker",
  "build": {
    "frontendDist": "../src-tauri-placeholder",
    "devUrl": "http://127.0.0.1:3210",
    "beforeDevCommand": "npm run dev:desktop",
    "beforeBuildCommand": "npm run build:desktop"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Track Republic",
        "width": 1480,
        "height": 960,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../desktop-runtime": "desktop-runtime"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
